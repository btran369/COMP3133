  "item": [
    {
      "name": "01 Auth",
      "item": [
        {
          "name": "Signup (Mutation)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation ($input: SignupInput!) { Signup(input: $input) { success message token user { _id username email created_at updated_at } } }\",\n  \"variables\": {\n    \"input\": {\n      \"username\": \"demo_user_1\",\n      \"email\": \"demo_user_1@example.com\",\n      \"password\": \"Password123!\"\n    }\n  }\n}\n"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('No GraphQL errors', function () { pm.expect(json.errors).to.be.undefined; });",
                  "pm.test('Signup success true', function () { pm.expect(json.data.Signup.success).to.eql('true'); });",
                  "if (json?.data?.Signup?.token) {",
                  "  pm.collectionVariables.set('token', json.data.Signup.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (Query)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query ($input: LoginInput!) { Login(input: $input) { success message token user { _id username email } } }\",\n  \"variables\": {\n    \"input\": {\n      \"usernameOrEmail\": \"demo_user_1\",\n      \"password\": \"Password123!\"\n    }\n  }\n}\n"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('No GraphQL errors', function () { pm.expect(json.errors).to.be.undefined; });",
                  "pm.test('Login success true', function () { pm.expect(json.data.Login.success).to.eql('true'); });",
                  "pm.test('Token returned', function () { pm.expect(json.data.Login.token).to.be.a('string'); });",
                  "pm.collectionVariables.set('token', json.data.Login.token);"
                ]
              }
            }
          ]
        }
      ]

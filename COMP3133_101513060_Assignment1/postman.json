          "name": "GetAllEmployees (Query)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { GetAllEmployees { _id first_name last_name email gender designation salary date_of_joining department employee_photo created_at updated_at } }\"\n}\n"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('No GraphQL errors', function () { pm.expect(json.errors).to.be.undefined; });",
                  "pm.test('Returns an array', function () { pm.expect(json.data.GetAllEmployees).to.be.an('array'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "AddEmployee (Mutation) - with photo (multipart)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "operations",
                  "type": "text",
                  "value": "{\n  \"query\": \"mutation ($input: EmployeeInput!, $photo: Upload) { AddEmployee(input: $input, photo: $photo) { success message employee { _id first_name last_name email employee_photo } } }\",\n  \"variables\": {\n    \"input\": {\n      \"first_name\": \"Jane\",\n      \"last_name\": \"Doe\",\n      \"email\": \"jane.doe@example.com\",\n      \"gender\": \"Female\",\n      \"designation\": \"Developer\",\n      \"salary\": 5000,\n      \"date_of_joining\": \"2026-02-01\",\n      \"department\": \"IT\"\n    },\n    \"photo\": null\n  }\n}\n"
                },
                {
                  "key": "map",
                  "type": "text",
                  "value": "{ \"0\": [\"variables.photo\"] }"
                },
                {
                  "key": "0",
                  "type": "file",
                  "src": ""
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('No GraphQL errors', function () { pm.expect(json.errors).to.be.undefined; });",
                  "pm.test('AddEmployee success true', function () { pm.expect(json.data.AddEmployee.success).to.eql('true'); });",
                  "pm.test('Employee id returned', function () { pm.expect(json.data.AddEmployee.employee._id).to.be.a('string'); });",
                  "pm.collectionVariables.set('eid', json.data.AddEmployee.employee._id);"
                ]
              }
            }
          ]
        },
        {
